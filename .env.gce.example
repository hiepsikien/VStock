# Copy on GCE VM:  cp .env.gce.example .env  then fill secrets.
# Used by docker compose (same directory as docker-compose.yml).

API_PORT=8000

# Option A — Google AI Studio (simplest)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Option B — Vertex AI via VM service account (no API key)
# Grant VM SA: roles/aiplatform.user
# GCP_PROJECT=vstock-prod
# GCP_LOCATION=asia-southeast1
# GEMINI_MODEL=gemini-3.5-flash
