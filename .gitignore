# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
# Local / secrets (not committed)
.env
.env*.local

# Mode files (.env.development / .env.production) MAY be committed
# when they only contain public API URLs — no API keys.

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Python backend
backend/.venv/
backend/**/__pycache__/
backend/**/*.pyc
backend/data/
.pytest_cache/

# Editor / agent
.claude/
