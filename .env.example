EXPO_PUBLIC_API_URL=http://localhost:8000

# Production example (after GCE deploy — see docs/DEPLOY-GCE.md):
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# Backend (local Companion AI) — set in backend shell / .env, not Expo:
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# Or Vertex: GCP_PROJECT=... GCP_LOCATION=asia-southeast1
