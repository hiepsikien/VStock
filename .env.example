# Copy to the mode you need, or rely on committed:
#   .env.development  → local API
#   .env.production   → GCE API
#
# Expo: `npx expo start` uses development mode.
# Override once: `npm run start:gce`

EXPO_PUBLIC_API_URL=http://localhost:8000

# Production example:
# EXPO_PUBLIC_API_URL=http://34.142.248.53:8000

# Backend (Companion) — export in the API terminal, not Expo:
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
# Or Vertex: GCP_PROJECT=... GCP_LOCATION=asia-southeast1
