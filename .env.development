# Local Expo (`npx expo start` / npm start)
# Simulator / LAN: uses EXPO_PUBLIC_API_URL (rewrites localhost → Mac LAN IP).
# Physical device + tunnel: uses EXPO_PUBLIC_DEVICE_API_URL (cloud).
# Uvicorn local: uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_DEVICE_API_URL=http://34.126.117.158:8000
